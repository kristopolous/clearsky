# Clearsky Environment Configuration
# Copy this file to .env and configure for your setup

# Podman configuration
PODMAN_RUNTIME=podman

# Immich configuration
IMMICH_HOST=http://localhost:2283
IMMICH_KEY=dummy

# Data directory
DATA_DIR=$HOME/.clearsky

# Logging
LOG_LEVEL=info
LOG_DIR=$DATA_DIR/logs

# Tailscale configuration
TS_AUTHKEY=
TS_STATE_DIR=$DATA_DIR/tailscale