{
  "name": "clearsky",
  "version": "1.0.0",
  "description": "No More Clouds - Migrate your data to self-hosted services",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux appimage",
    "build:linux": "electron-builder --linux appimage",
    "build:mac": "electron-builder --mac --universal",
    "build:mac:intel": "electron-builder --mac --x64",
    "build:mac:arm": "electron-builder --mac --arm64",
    "build:all": "electron-builder --mac --linux"
  },
  "keywords": [
    "cloud",
    "migration",
    "self-hosted",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "node-fetch": "^3.3.2",
    "toml": "^3.0.0"
  },
  "build": {
    "appId": "com.clearsky.app",
    "productName": "Clearsky",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "notarize": false,
      "minimumSystemVersion": "10.13"
    },
    "dmg": {
      "title": "Clearsky",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
